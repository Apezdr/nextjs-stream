{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/**/page.{js,jsx,ts,tsx}",
    "src/app/**/layout.{js,jsx,ts,tsx}",
    "src/app/**/loading.{js,jsx,ts,tsx}",
    "src/app/**/template.{js,jsx,ts,tsx}",
    "src/app/**/error.{js,jsx,ts,tsx}",
    "src/app/**/not-found.{js,jsx,ts,tsx}",
    "src/app/**/route.{js,ts}",
    "src/pages/**/*.{js,jsx,ts,tsx}",
    "src/utils/config.js",
    "src/utils/monitor_server_load.js",
    "scripts/**/*.{js,ts}",
    "src/components/Search/**/*.{js,jsx,ts,tsx}",
    "src/components/Calendar/**/*.{js,jsx,ts,tsx}",
    "src/components/Landing/**/*.{js,jsx,ts,tsx}",
    "src/components/Navigation/DeviceLinkModal.{js,jsx,ts,tsx}",
    "src/components/notifications/NotificationBell.{js,jsx,ts,tsx}",
    "src/components/HOC/ShouldRenderContent.{js,jsx,ts,tsx}",
    "src/components/MediaScroll/CardVideoPlayer.{js,jsx,ts,tsx}"
  ],
  "project": ["src/**/*.{js,jsx,ts,tsx}", "scripts/**/*.{js,ts}"],
  "paths": {
    "@src/*": ["./src/*"],
    "@components/*": ["./src/components/*"]
  },
  "ignore": [
    "**/__mocks__/**"
  ],
  "ignoreDependencies": [
    "sharp",
    "@eslint/js",
    "media-icons"
  ],
  "ignoreExportsUsedInFile": true
}
